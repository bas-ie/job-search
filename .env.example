# Copy this file to .env and fill in your values. .env is gitignored.
#
# Loaded automatically by `uv run` when UV_ENV_FILE=.env is set in your shell,
# or explicitly via `uv run --env-file .env ...`.

# Anthropic API key (used by the `score` command).
JOB_SEARCH_API_KEY=

# Path to your CV. Plain text, Markdown, or LaTeX all work.
JOB_SEARCH_CV_PATH=./cv.md
